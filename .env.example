# Backend API (optional — defaults to http://localhost:3000/api)
# VITE_API_URL=http://localhost:3000/api
# VITE_BACKEND=localhost:3000

# Google OAuth (must match CoalMine-B GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Gemini is configured on the BACKEND only (CoalMine-B/.env GEMINI_API_KEY)
# Do not put API keys in VITE_* variables unless you accept exposing them in the browser.
