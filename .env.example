# Backend API (optional — defaults to http://localhost:3000/api)
# VITE_API_URL=http://localhost:3000/api
# VITE_BACKEND=localhost:3000

# Google OAuth (must match CoalMine-B GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Firebase (client SDK — values from Firebase console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# OpenWeather (weather widget)
VITE_OPENWEATHER_API_KEY=

# TinyMCE (optional rich text editor)
# VITE_TINYMCE_API_KEY=

# Gemini is configured on the BACKEND only (CoalMine-B/.env GEMINI_API_KEY)
# Do not put API keys in VITE_* variables unless you accept exposing them in the browser.
